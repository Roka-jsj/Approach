ARG ROS_DISTRO=humble
ARG BASE_IMAGE=ros:${ROS_DISTRO}-ros-base-jammy
FROM ${BASE_IMAGE}

ARG ROS_DISTRO=humble
ENV ROS_DISTRO=${ROS_DISTRO}
ENV DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-c"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    python3-colcon-common-extensions \
    ros-${ROS_DISTRO}-ament-cmake \
    ros-${ROS_DISTRO}-geometry-msgs \
    ros-${ROS_DISTRO}-nav2-msgs \
    ros-${ROS_DISTRO}-rclpy \
    ros-${ROS_DISTRO}-rosidl-default-generators \
    ros-${ROS_DISTRO}-std-msgs \
    ros-${ROS_DISTRO}-tf2-ros \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/nvidia/ros2_ws/src/approach

COPY . /home/nvidia/ros2_ws/src/approach
COPY docker/ros_entrypoint.sh /ros_entrypoint.sh

RUN test -f /home/nvidia/ros2_ws/src/approach/yolo_msgs/package.xml     || (echo "ERROR: yolo_msgs/package.xml not found. Copy yolo_msgs into the Docker build context at ~/approach/yolo_msgs." && exit 1)

RUN chmod +x /ros_entrypoint.sh \
    && chmod +x /home/nvidia/ros2_ws/src/approach/stella_approach/scripts/approach_goal_service.py \
    && source /opt/ros/${ROS_DISTRO}/setup.bash \
    && cd /home/nvidia/ros2_ws \
    && colcon build \
        --base-paths /home/nvidia/ros2_ws/src/approach/yolo_msgs /home/nvidia/ros2_ws/src/approach/stella_approach \
        --packages-up-to yolo_msgs stella_approach \
        --build-base /home/nvidia/ros2_ws/build \
        --install-base /home/nvidia/ros2_ws/install \
        --symlink-install \
    && mkdir -p /home/nvidia/ros2_ws/install/stella_approach/share/stella_approach/launch \
    && if [ ! -f /home/nvidia/ros2_ws/install/stella_approach/share/stella_approach/launch/approach_goal.launch.py ]; then \
         cp /home/nvidia/ros2_ws/src/approach/stella_approach/launch/approach_goal.launch.py /home/nvidia/ros2_ws/install/stella_approach/share/stella_approach/launch/approach_goal.launch.py; \
       fi \
    && mkdir -p /home/nvidia/ros2_ws/install/stella_approach/lib/stella_approach \
    && if [ ! -x /home/nvidia/ros2_ws/install/stella_approach/lib/stella_approach/approach_goal_service.py ]; then \
         cp /home/nvidia/ros2_ws/src/approach/stella_approach/scripts/approach_goal_service.py /home/nvidia/ros2_ws/install/stella_approach/lib/stella_approach/approach_goal_service.py; \
         chmod +x /home/nvidia/ros2_ws/install/stella_approach/lib/stella_approach/approach_goal_service.py; \
       fi \
    && test -f /home/nvidia/ros2_ws/install/stella_approach/share/stella_approach/launch/approach_goal.launch.py \
    && test -x /home/nvidia/ros2_ws/install/stella_approach/lib/stella_approach/approach_goal_service.py \
    && source /home/nvidia/ros2_ws/install/setup.bash \
    && python3 -c "from yolo_msgs.msg import DetectionArray; from yolo_msgs.srv import GetTargetPosition; from stella_approach.srv import ApproachTarget"

WORKDIR /home/nvidia/ros2_ws

ENTRYPOINT ["/ros_entrypoint.sh"]
CMD ["ros2", "launch", "stella_approach", "approach_goal.launch.py"]
